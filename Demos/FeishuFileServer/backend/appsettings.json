{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=FeishuFile.db"
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Mud.Feishu": "Information"
    }
  },
  "AllowedHosts": "*",
  "FeishuApps": [
    {
      "AppKey": "default",
      "AppId": "cli_xxxxxxxxxxxxxxxxxx",
      "AppSecret": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "BaseUrl": "https://open.feishu.cn",
      "TimeOut": 30,
      "RetryCount": 3,
      "EnableLogging": true,
      "IsDefault": true
    }
  ],
  "FileUploadSettings": {
    "AllowedExtensions": [
      ".docx",
      ".xlsx",
      ".pptx",
      ".png",
      ".jpg",
      ".jpeg",
      ".tiff",
      ".pdf"
    ],
    "MaxFileSizeMB": 100,
    "EnableChunkUpload": true,
    "ChunkSizeMB": 5,
    "EnableDeduplication": true
  },
  "VersionManagement": {
    "Enabled": true,
    "MaxVersionsPerFile": 50
  },
  "CorsSettings": {
    "AllowedOrigins": ["http://localhost:3000"],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["*"]
  },
  "JwtSettings": {
    "Secret": "YourSuperSecretKeyForJwtTokenGeneration2024!@#$%^&*()_+=-{}[]|;':,./<>?25:",
    "Issuer": "FeishuFileServer",
    "Audience": "FeishuFileClient",
    "ExpirationHours": 24
  }
}
