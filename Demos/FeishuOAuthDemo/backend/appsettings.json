{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Mud.Feishu": "Debug"
    }
  },
  "AllowedHosts": "*",
  "Feishu": {
    "AppId": "cli_xxxxxxxxxxxxxxxx",
    "AppSecret": "your-app-secret-here",
    "BaseUrl": "https://open.feishu.cn",
    "TimeOut": 30,
    "RetryCount": 3,
    "TokenRefreshThreshold": 300,
    "EnableLogging": true
  },
  "OAuth": {
    "RedirectUri": "http://localhost:5173/auth/feishu/callback",
    "Jwt": {
      "Secret": "your-256-bit-secret-key-for-jwt-token-generation-min-32-chars",
      "Issuer": "FeishuOAuthDemo",
      "Audience": "FeishuOAuthUsers",
      "ExpirationMinutes": 1440
    },
    "StateExpirationMinutes": 5
  }
}
